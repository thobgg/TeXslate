<?xml version="1.0" encoding="utf-8"?><!--
   Backup-/Transfer-Regeln ab API 31.
   Die KI-Einstellungen (ai_settings.xml) enthalten die verschlüsselten API-Keys;
   der zugehörige Keystore-Schlüssel verlässt das Gerät nie — der Chiffretext ist
   auf anderen Geräten nicht entschlüsselbar und wird deshalb weder in die Cloud
   gesichert noch bei Gerät-zu-Gerät-Übertragung mitgenommen.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="ai_settings.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="ai_settings.xml" />
    </device-transfer>
</data-extraction-rules>
