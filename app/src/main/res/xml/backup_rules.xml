<?xml version="1.0" encoding="utf-8"?><!--
   Backup-Regeln für Geräte bis API 30 (ab API 31 gilt data_extraction_rules.xml).
   Die KI-Einstellungen (ai_settings.xml) enthalten die verschlüsselten API-Keys;
   der zugehörige Keystore-Schlüssel verlässt das Gerät nie — ein gesicherter
   Chiffretext wäre auf anderen Geräten wertlos und hat im Backup nichts verloren.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="ai_settings.xml" />
</full-backup-content>
