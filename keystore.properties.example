# Vorlage für die Release-Signierung.
# Kopieren nach  keystore.properties  (wird NICHT eingecheckt) und ausfüllen.
# Der Keystore texdroid-release.jks liegt im Projekt-Root (ebenfalls gitignored).
storeFile=texdroid-release.jks
storePassword=DEIN_KEYSTORE_PASSWORT
keyAlias=texdroid
keyPassword=DEIN_KEY_PASSWORT
